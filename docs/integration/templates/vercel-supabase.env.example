# Vercel(웹) + Supabase(DB) + BFF(별도 호스팅) 조합 시 참고
# 값은 각 플랫폼 Secrets에만 저장합니다.

# --- Vercel · Project Settings → Environment Variables (apps/web 빌드 시) ---
# VITE_SUITE_BFF_BASE=https://your-bff.example.com
# VITE_SUITE_BFF_JWT=  # 프로덕션은 비우거나 단기 토큰만; 장기 키는 번들에 넣지 않음

# --- BFF 호스팅 (Fly/Railway/Render 등; Vercel Serverless 전체 이전은 워커 때문에 비권장) ---
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# BFF_API_KEY=
# BFF_ADMIN_KEY=
# JWT_SECRET=  # 또는 Supabase JWT secret으로 HS256 검증
# JWKS_URI=    # Supabase / Auth 제공 JWKS 사용 시
# JWT_ISSUER=
# JWT_AUDIENCE=
# BFF_WEBHOOK_SIGNING_SECRET=
# BFF_ENFORCE_TENANT_HEADER=1

# --- Supabase Dashboard (저장소에 커밋 금지) ---
# service_role 키 → 오직 BFF 서버 환경에만
# Yuaimarketing이 프로젝트를 관리하는 경우 전달 절차: docs/integration/SUPABASE_KEYS_HANDOFF.md
