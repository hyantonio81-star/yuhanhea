# 스테이징 통합용 환경 변수 템플릿 (1.4)
# 실제 값은 비밀 저장소에만 두고, 배포 플랫폼 시크릿에 주입합니다.

# --- BFF (apps/api) ---
# 쉼표 구분 허용 Origin. 미설정 시 CORS는 * (개발 편의). 프로덕션에서는 Vercel 도메인 등 명시 권장.
# BFF_CORS_ORIGINS=https://app.example.com,https://staging.example.com
PORT=8787
DATA_DIR=/var/lib/yuhan-suite
# BFF_API_KEY=
# BFF_ADMIN_KEY=
# JWT_SECRET=
# JWKS_URI=
# JWT_ISSUER=
# JWT_AUDIENCE=
# BFF_ENFORCE_TENANT_HEADER=
# ASSISTANT_TOOL_APPROVAL_QUEUE=
# SQLITE_PATH=

# ERP·아웃박스 (선택: 발신 HMAC)
# BFF_WEBHOOK_SIGNING_SECRET=
# ERP_FINANCE_WEBHOOK_URL=https://erp-staging.example.com/webhooks/finance
# OUTBOX_WEBHOOK_URL=https://bus-staging.example.com/inbox
# OUTBOX_MIRROR_URL=https://bus-staging.example.com/outbox-mirror
# OUTBOX_FAILURE_WEBHOOK_URL=https://alerts.example.com/hooks/outbox-failed
# OUTBOX_POLL_MS=5000
# OUTBOX_MAX_ATTEMPTS=8

# REMINDER_WEBHOOK_URL=

# --- Web (apps/web) — 빌드 시 Vite ---
# VITE_SUITE_BFF_BASE=https://bff-staging.example.com
# VITE_SUITE_BFF_KEY=
# VITE_SUITE_BFF_ADMIN_KEY=
