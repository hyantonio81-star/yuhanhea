{
  "name": "yuhan-mart",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w yuhan-suite-api\" \"npm run dev -w web\"",
    "build": "npm run build -w yuhan-suite-api && npm run build -w web",
    "verify": "npm run verify -w web && npm run verify:contract",
    "verify:contract": "node scripts/verify-contract.mjs",
    "smoke:bff": "node scripts/smoke-bff.mjs",
    "smoke:e2e": "node scripts/e2e-integration-local.mjs",
    "webhook:stub": "node scripts/webhook-stub.mjs",
    "export:audit": "npm run export-audit -w yuhan-suite-api",
    "security:check": "node scripts/security-check.mjs",
    "e2e": "npm run e2e -w web",
    "vercel:link": "npx vercel@latest link --yes --team team_aCjAaszaGiTD9WCNfVriVHsP --project yuhanhea-web",
    "vercel:env": "npx vercel@latest env pull",
    "vercel:deploy": "npx vercel@latest deploy",
    "vercel:deploy:prod": "npx vercel@latest deploy --prod"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
