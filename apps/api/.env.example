PORT=8787
# 감사·멱등·아웃박스 — SQLite (기본 data/suite.db). 끄려면 SQLITE_DISABLED=1
# SQLITE_PATH=
# SQLITE_DISABLED=
# 아웃박스 pending → POST 재시도 (전체 이벤트)
# OUTBOX_WEBHOOK_URL=
# INSERT 직후 동일 이벤트를 한 번 더 POST (버스/큐 어댑터용, 선택). HMAC은 BFF_WEBHOOK_SIGNING_SECRET 공유
# OUTBOX_MIRROR_URL=
# OUTBOX_FAILURE_WEBHOOK_URL=
# OUTBOX_POLL_MS=5000
# OUTBOX_MAX_ATTEMPTS=8
# 재무 이벤트 즉시 POST (아웃박스와 별도)
# ERP_FINANCE_WEBHOOK_URL=
# 발신 웹훅 공통 HMAC — 설정 시 X-Yuhan-Signature: sha256=<hex> (본문 UTF-8 기준)
# BFF_WEBHOOK_SIGNING_SECRET=
# 감사·멱등·아웃박스 파일 위치 (기본: ./data)
# DATA_DIR=
# HS256 검증용. 설정 시 Authorization: Bearer 또는 X-BFF-Key
# JWT_SECRET=
# OIDC 리소스 서버 (Bearer RS256 등). HS256 실패 후 또는 JWT_SECRET 없이 시도
# JWKS_URI=
# JWT_ISSUER=
# JWT_AUDIENCE=
# JWT에 tenant_id/tid가 있을 때 X-Tenant-Id와 일치 강제 (1/true)
# BFF_ENFORCE_TENANT_HEADER=
# 리마인더 생성 시 POST 전달 (선택)
# REMINDER_WEBHOOK_URL=
# 설정 시 모든 /api/v1 요청에 X-BFF-Key 헤더 필요 (웹은 VITE_SUITE_BFF_KEY)
# BFF_API_KEY=
# 실패한 아웃박스를 pending으로 되돌리는 관리 API (POST /api/v1/admin/outbox/:id/retry) — X-BFF-Admin-Key
# BFF_ADMIN_KEY=
# 리마인더 쿨다운(ms). 로컬 빠른 테스트: 60000
# BFF_REMINDER_COOLDOWN_MS=86400000
# AI 비서: Gemini 우선(권장), 없으면 OpenAI, 둘 다 없으면 휴리스틱
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# 테넌트+사용자당 분당 세션 수 (기본 20)
# ASSISTANT_RATE_LIMIT_PER_MIN=20
# 고위험 도구 호출을 DB 큐에 넣고 관리자 승인 후 아웃박스 반영 (1/true)
# ASSISTANT_TOOL_APPROVAL_QUEUE=
# 쉼표 구분 도구명 (기본: mkt_schedule_campaign,mart_create_video_job,crm_schedule_reminder)
# ASSISTANT_TOOL_APPROVAL_QUEUE_TOOLS=
