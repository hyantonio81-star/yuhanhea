# Yuhan Suite — 외부 허브 URL (선택). 없으면 앱 내 라우트만 사용.
VITE_SUITE_YUAI_URL=
VITE_SUITE_CRM_URL=
VITE_SUITE_ERP_URL=
# BFF (apps/api). Vite dev 프록시 `/api` → `http://127.0.0.1:8787` 이므로 로컬은 `/api` 권장.
VITE_SUITE_BFF_BASE=
# 프로덕션 번들 금지 권장 — 로컬/내부 전용 (동일 출처 프록시 권장)
VITE_SUITE_BFF_KEY=
# JWT_SECRET 으로 서명한 토큰 (BFF에 JWT_SECRET 설정 시)
VITE_SUITE_BFF_JWT=
# BFF BFF_ADMIN_KEY와 동일 — 승인 큐 등 관리 API만
VITE_SUITE_BFF_ADMIN_KEY=
# AI 보안 허브 (/suite/ai-security) 라벨: off | monitoring
VITE_AI_SECURITY_MODE=monitoring
# (선택) 비민감 상태 JSON URL
# VITE_SECURITY_UPDATES_FEED_URL=
# 사이드바: full | core (core = Suite·오케스트레이터·핵심만)
# VITE_NAV_SURFACE=full
